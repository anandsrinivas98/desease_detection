# ─────────────────────────────────────────────────────────────────
# CropVision Backend — Environment Variables Template
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# ⚠️  NEVER commit .env to version control — it contains secrets.
# ─────────────────────────────────────────────────────────────────

# ── Neon PostgreSQL ───────────────────────────────────────────────
# Get from: https://neon.tech → Project → Connection Details
# Format:   postgresql://user:password@host/dbname?sslmode=require
NEON_DATABASE_URL=postgresql://your_user:your_password@your_host.neon.tech/your_db?sslmode=require

# ── Google Gemini API ─────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# Free tier: 20 requests/day for gemini-2.5-flash
# Paid tier: https://ai.google.dev for unlimited requests
GEMINI_API_KEY=your_gemini_api_key_here
